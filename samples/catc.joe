catc:args.

args length; > 1 ifTrue {
   out <- !newInstance "java.io.OutputStreamWriter",
                       (!getStaticField "java.lang.System","out").
   file <- !newInstance "java.io.FileReader",(args get 1).
   buff <- !newArray "char",16.
   cnt := 0.
   !while { cnt := file read buff. cnt > 0 },{
      out write buff, 0, cnt.
   }.
   out close.
}.
